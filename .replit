modules = ["nodejs-20", "python-3.12", "web", "postgresql-16"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash -c 'cd backend && PORT=3001 HOST=127.0.0.1 JWT_SECRET=${JWT_SECRET:-dev-replit-jwt-secret-change-before-production} AI_ENGINE_URL=${AI_ENGINE_URL:-http://127.0.0.1:8000} npm start & cd frontend-web && npm run dev -- --host 0.0.0.0 --port 5000'"
waitForPort = 5000

[[ports]]
localPort = 3001
externalPort = 3001
exposeLocalhost = true

[[ports]]
localPort = 5000
externalPort = 80

[deployment]
deploymentTarget = "autoscale"
run = ["bash", "-c", "cd backend && HOST=0.0.0.0 PORT=5000 NODE_ENV=production SERVE_FRONTEND=true JWT_SECRET=${JWT_SECRET:-dev-replit-jwt-secret-change-before-production} AI_ENGINE_URL=${AI_ENGINE_URL:-http://127.0.0.1:8000} npm start"]
build = ["bash", "-c", "npm ci --prefix backend && npm ci --prefix frontend-web && npm run build --prefix frontend-web"]
