# Backend environment configuration
# Copy to .env and fill in real values before starting the backend.

# Backend server
PORT=3001
HOST=0.0.0.0

# JWT signing secret (must be kept secret)
JWT_SECRET=your_jwt_secret_here

# AI engine service URL
AI_ENGINE_URL=http://localhost:8000

# Database connection
DB_HOST=localhost
DB_PORT=5432
DB_NAME=cap_counseling
DB_USER=postgres
DB_PASSWORD=postgres
DB_SSL=false

# Local development options
DISABLE_RATE_LIMIT=false
RATE_LIMIT_MAX=1000
RATE_LIMIT_AUTH_MAX=50

# Optional AI / LLM provider keys
OPENAI_API_KEY=your_openai_api_key
ANTHROPIC_API_KEY=your_anthropic_api_key

# Frontend dev proxy
# Frontend uses VITE_API_URL in frontend-web/.env.local, not this .env file.
